# Copy this to .env and fill in your credentials.
# .env is gitignored — never commit real tokens.

# Alpaca
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# eToro Open API
ETORO_API_KEY=
ETORO_USER_KEY=

# cTrader / Pepperstone (obtain from your broker's API portal)
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=
CTRADER_ACCESS_TOKEN=
CTRADER_REFRESH_TOKEN=
